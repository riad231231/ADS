<?xml version="1.0" encoding="utf-8"?>
<extension type="file" version="2.5" method="upgrade">
 
        <!-- Please use a unique name to make uninstall to work. Should be identical to your manifest filename. -->
        <name>com_jem_fr-FR</name>
		<tag>fr-FR</tag>
        <author>French Translation Team</author>
        <creationDate>18 December 2014</creationDate>
        <copyright>(C) 2005-2014 Christopher Lukes / JEM Translation Team</copyright>
        <license>http://www.gnu.org/licenses/gpl-2.0.html GNU/GPL</license>
        <authorEmail>info@joomlaeventmanager.net</authorEmail>
        <authorUrl>http://www.joomlaeventmanager.net</authorUrl>
        <version>2.0.3</version>
        <description>This is the fr-FR language pack for JEM - an Event Manager for Joomla!
						For assistance in translations please visit the Transifex Project page of JEM at http://www.transifex.com/projects/p/JEM/
		</description>
 
        <!-- Fileset definition -->
        <fileset>
 
                <!-- back-end -->
                <files folder="admin_fr-FR" target="administrator/components/com_jem/language/fr-FR">
				        <filename>fr-FR.com_jem.ini</filename>
                        <filename>fr-FR.com_jem.sys.ini</filename>
                </files>
 
                <!-- front-end -->
				<files folder="site_fr-FR" target="components/com_jem/language/fr-FR">
                        <filename>fr-FR.com_jem.ini</filename>			 
                </files>
				
				<!-- modules -->
				<files folder="site_fr-FR" target="modules/mod_jem/language/fr-FR">
                        <filename>fr-FR.mod_jem.ini</filename>
						<filename>fr-FR.mod_jem.sys.ini</filename>
			    </files>
				
				<files folder="site_fr-FR" target="modules/mod_jem_wide/language/fr-FR">
                        <filename>fr-FR.mod_jem_wide.ini</filename>
						<filename>fr-FR.mod_jem_wide.sys.ini</filename>
			    </files>	
				
				<files folder="site_fr-FR" target="modules/mod_jem_cal/language/fr-FR">
                        <filename>fr-FR.mod_jem_cal.ini</filename>
						<filename>fr-FR.mod_jem_cal.sys.ini</filename>
			    </files>
				
				<files folder="site_fr-FR" target="modules/mod_jem_teaser/language/fr-FR">
                        <filename>fr-FR.mod_jem_teaser.ini</filename>
						<filename>fr-FR.mod_jem_teaser.sys.ini</filename>
			    </files>	
								
				<!-- plugins -->				
				<files folder="site_fr-FR" target="plugins/finder/jem/language/fr-FR">
                        <filename>fr-FR.plg_finder_jem.ini</filename>
						<filename>fr-FR.plg_finder_jem.sys.ini</filename>
			    </files>

				<files folder="site_fr-FR" target="plugins/jem/comments/language/fr-FR">
                        <filename>fr-FR.plg_jem_comments.ini</filename>
						<filename>fr-FR.plg_jem_comments.sys.ini</filename>
			    </files>
				
				<files folder="site_fr-FR" target="plugins/jem/mailer/language/fr-FR">
                        <filename>fr-FR.plg_jem_mailer.ini</filename>
						<filename>fr-FR.plg_jem_mailer.sys.ini</filename>
			    </files>
				
				<files folder="site_fr-FR" target="plugins/search/jem/language/fr-FR">
                        <filename>fr-FR.plg_search_jem.ini</filename>
						<filename>fr-FR.plg_search_jem.sys.ini</filename>
			    </files>

				
        </fileset>
</extension>

